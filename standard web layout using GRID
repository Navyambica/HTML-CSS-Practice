<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>design standard web layout using GRID</title>
  <style>
    *{
      box-sizing: border-box;
    }
  .container {
    height: 400px;
    width: 600px;
    border: 1px solid;
    display: grid;
    grid-template-rows: 50px 300px 50px;/* height*/
    grid-template-columns: 250px 250px 100px;/*width*/

  }
  .box1 {
    border: 1px solid;
    grid-column-start: 1;
    grid-column-end: 4;
    padding: 15px;
    display: flex;
    justify-content: center;
    color: white;
    background-color: #100d0d;
    font-size: 20px;
}
   .box2{
    border: 1px solid;
   padding: 7px;
   background-color: #e3dbdb;
    
  }
   .box3{
    border: 1px solid;
    grid-column-start: 2;
    grid-column-end: 4;
   padding: 7px;
  }
   .box4{
    border: 1px solid;
    grid-column-start: 1;
    grid-column-end: 4;
    display: flex;
    justify-content: center;
    padding: 15px;
    font-size: 20px;
    background-color: black;
    color: white;
  }
   </style>
</head>
<body>
<div class="container">
  <div class="box1">Header</div>
  <div class="box2">
    <h2>Sidebar</h2>
  <p>The Menu or quick access content</p></div>
  <div class="box3">
    <h2>Main Content</h2>
    <p>The core website content should be displayed here</p>
  </div>
  <div class="box4">Footer</div>
</div>
</body>
</html>
